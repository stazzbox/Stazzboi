<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>PHOTOS | Stazzboi.com</title>

<meta name="description" content="Official media gallery and visual archive connected to STAZZBOI, Stazzeria, The Stazzlies, and Stazzology.">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html{
    scroll-behavior:smooth;
}

body{
    font-family:Arial, Helvetica, sans-serif;
    background:#050505;
    color:white;
    overflow-x:hidden;
}

/* NAVBAR */

.navbar{
    width:100%;
    position:fixed;
    top:0;
    left:0;

    display:flex;
    justify-content:space-between;
    align-items:center;

    padding:22px 60px;

    background:rgba(0,0,0,0.45);

    backdrop-filter:blur(12px);
    -webkit-backdrop-filter:blur(12px);

    border-bottom:1px solid rgba(255,255,255,0.08);

    z-index:999;
}

.logo{
    font-size:1.4rem;
    font-weight:700;
    letter-spacing:3px;
    text-decoration:none;
    color:white;
}

.nav-links{
    display:flex;
    gap:28px;
}

.nav-links a{
    text-decoration:none;
    color:rgba(255,255,255,0.82);
    transition:0.3s ease;
    font-size:0.95rem;
}

.nav-links a:hover{
    color:#ffffff;
}

/* HERO */

.hero{
    width:100%;
    padding:180px 8% 80px;
    text-align:center;
}

.hero h1{
    font-size:5rem;
    letter-spacing:8px;
    margin-bottom:20px;
}

.hero p{
    max-width:800px;
    margin:auto;

    line-height:1.9;

    color:rgba(255,255,255,0.72);

    font-size:1.05rem;
}

/* CATEGORY FILTER */

.category-bar{
    width:100%;
    padding:0 8% 60px;
}

.category-container{
    width:100%;
    max-width:1200px;

    margin:auto;

    display:flex;
    justify-content:center;
    gap:18px;
    flex-wrap:wrap;
}

.category-btn{
    padding:14px 24px;

    border-radius:50px;

    border:1px solid rgba(255,255,255,0.12);

    background:rgba(255,255,255,0.04);

    color:white;

    font-size:0.92rem;

    letter-spacing:1px;

    transition:0.3s ease;

    cursor:pointer;
}

.category-btn:hover{
    background:white;
    color:black;
}

/* GALLERY */

.gallery{
    width:100%;
    padding:0 8% 120px;
}

.gallery-grid{
    width:100%;
    max-width:1500px;

    margin:auto;

    columns:3 320px;
    column-gap:24px;
}

.gallery-item{
    position:relative;

    margin-bottom:24px;

    overflow:hidden;

    border-radius:24px;

    border:1px solid rgba(255,255,255,0.08);

    background:rgba(255,255,255,0.03);

    break-inside:avoid;

    transition:0.35s ease;
}

.gallery-item:hover{
    transform:translateY(-5px);

    border-color:rgba(255,255,255,0.18);

    box-shadow:
    0 0 35px rgba(255,255,255,0.05);
}

.gallery-item img{
    width:100%;
    display:block;
}

/* OVERLAY */

.gallery-overlay{
    position:absolute;

    bottom:0;
    left:0;

    width:100%;

    padding:24px;

    background:linear-gradient(
        to top,
        rgba(0,0,0,0.88),
        transparent
    );

    opacity:0;

    transition:0.35s ease;
}

.gallery-item:hover .gallery-overlay{
    opacity:1;
}

.gallery-overlay h3{
    font-size:1.2rem;
    margin-bottom:8px;
}

.gallery-overlay p{
    color:rgba(255,255,255,0.72);
    font-size:0.92rem;
}

/* COLLECTIONS */

.collections{
    width:100%;
    padding:100px 8%;
}

.collections-container{
    width:100%;
    max-width:1400px;
    margin:auto;
}

.collections-header{
    text-align:center;
    margin-bottom:60px;
}

.collections-header h2{
    font-size:3rem;
    letter-spacing:4px;
    margin-bottom:18px;
}

.collections-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
}

.collection-card{
    background:rgba(255,255,255,0.04);

    border:1px solid rgba(255,255,255,0.08);

    border-radius:28px;

    padding:35px;

    transition:0.35s ease;

    text-align:center;
}

.collection-card:hover{
    transform:translateY(-8px);

    border-color:rgba(255,255,255,0.18);

    box-shadow:
    0 0 35px rgba(255,255,255,0.05);
}

.collection-card h3{
    margin-bottom:16px;
    letter-spacing:2px;
}

.collection-card p{
    line-height:1.8;
    color:rgba(255,255,255,0.72);
}

/* DIRECTORY */

.directory{
    width:100%;
    padding:100px 8%;
}

.directory-container{
    width:100%;
    max-width:1200px;
    margin:auto;
    text-align:center;
}

.directory-container h3{
    font-size:3rem;
    margin-bottom:45px;
    letter-spacing:4px;
}

.directory-links{
    display:flex;
    justify-content:center;
    gap:25px;
    flex-wrap:wrap;
}

.directory-links a{
    text-decoration:none;

    color:white;

    border:1px solid rgba(255,255,255,0.14);

    padding:15px 24px;

    border-radius:50px;

    transition:0.3s ease;

    background:rgba(255,255,255,0.04);
}

.directory-links a:hover{
    background:white;
    color:black;
}

/* FOOTER */

.footer{
    padding:40px 20px;
    text-align:center;
    color:rgba(255,255,255,0.5);
    letter-spacing:2px;
}

/* MOBILE */

@media(max-width:1000px){

    .collections-grid{
        grid-template-columns:1fr;
    }

    .hero h1{
        font-size:3rem;
    }

}

@media(max-width:700px){

    .navbar{
        padding:20px;
        flex-direction:column;
        gap:15px;
    }

    .nav-links{
        flex-wrap:wrap;
        justify-content:center;
    }

    .hero h1{
        font-size:2.3rem;
    }

    .collections-header h2,
    .directory-container h3{
        font-size:2rem;
    }

}

</style>

</head>
